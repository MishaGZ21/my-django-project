# Django settings
DEBUG=true

# Hostnames/IPs allowed to serve the app (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.XX,my-pc.local
# CSRF_TRUSTED_ORIGINS=http://192.168.1.XX

# Secret key — generate your own: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# WhatsApp (Meta Business API)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_LANG=ru

# Куда слать руководителю (через запятую, формат E.164)
WHATSAPP_MANAGER_NUMBERS=7XXXXXXXXXXX
WHATSAPP_BYPASS_E164=7XXXXXXXXXXX

# Имена УТВЕРЖДЁННЫХ шаблонов в Meta
WHATSAPP_TPL_CLIENT_ORDER_PAID=client_order_paid_ru
WHATSAPP_TPL_MANAGER_ORDER_CREATED=manager_order_created_ru
WHATSAPP_TPL_MANAGER_PAYMENT=manager_payment_ru

# Для вебхука
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me

# Optional: media/static overrides
# MEDIA_URL=/media/
# MEDIA_ROOT=/absolute/path/to/media
# STATIC_ROOT=/absolute/path/to/staticfiles
